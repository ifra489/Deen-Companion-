<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main App Theme -->
    <style name="Theme.DeenCompanion" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.DeenCompanion.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D0D1A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.DeenCompanion</item>
    </style>

</resources>