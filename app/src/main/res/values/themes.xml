<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main App Theme -->
    <style name="Theme.DeenCompanion" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Minimal Theme for SplashActivity to avoid system splash -->
    <style name="Theme.DeenCompanion.NoSystemSplash" parent="Theme.DeenCompanion">
        <item name="android:windowBackground">@drawable/splash_bg</item>
    </style>

    <!-- Splash Theme (kept for reference / backup) -->
    <style name="Theme.DeenCompanion.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#141C48</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.DeenCompanion.NoSystemSplash</item>
    </style>

</resources>